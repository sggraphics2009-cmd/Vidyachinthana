    async function updateRecommendations() {
        if (!currentUser) return;
        const historySnap = await db.collection('users').doc(currentUser.uid).collection('history').get();
        const savedSnap = await db.collection('users').doc(currentUser.uid).collection('saved').get();
        const interactedIds = new Set();
        historySnap.forEach(d => interactedIds.add(d.id));
        savedSnap.forEach(d => interactedIds.add(d.id));
        const allArts = allArticles.filter(a => a.status === 'published');
        const tagFrequency = {};
        for (let art of allArts) {
            if (interactedIds.has(art.id)) {
                (art.tags || []).forEach(tag => tagFrequency[tag] = (tagFrequency[tag] || 0) + 1);
            }
        }
        const scored = allArts.map(art => {
            if (interactedIds.has(art.id)) return { art, score: -1 };
            let score = 0;
            (art.tags || []).forEach(tag => score += tagFrequency[tag] || 0);
            return { art, score };
        });
        const top = scored.filter(s => s.score > 0).sort((a,b)=>b.score-a.score).slice(0,5);
        const recDiv = document.getElementById('recommendList');
        if (top.length === 0) {
            recDiv.innerHTML = '<p>තවම නිර්දේශ සඳහා ප්‍රමාණවත් දත්ත නැත. ලිපි කියවන්න, සුරකින්න.</p>';
            return;
        }
        let html = '<div style="display:grid; gap:1rem;">';
        top.forEach(({art}) => {
            html += `<div class="article-card" data-id="${art.id}" style="cursor:pointer;"><div class="card-content"><div class="card-title">${escapeHtml(art.title)}</div></div></div>`;
        });
        html += '</div>';
        recDiv.innerHTML = html;
        document.querySelectorAll('#recommendList .article-card').forEach(card => {
            card.addEventListener('click', () => {
                const id = card.getAttribute('data-id');
                const art = allArticles.find(a => a.id === id);
                if (art) openArticleModal(art);
            });
        });
    }

