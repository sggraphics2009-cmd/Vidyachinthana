<script>
    // ==================== FIREBASE CONFIG ====================
    const firebaseConfig = {
        apiKey: "YOUR_API_KEY",
        authDomain: "YOUR_AUTH_DOMAIN",
        projectId: "YOUR_PROJECT_ID",
        storageBucket: "YOUR_STORAGE_BUCKET",
        messagingSenderId: "YOUR_SENDER_ID",
        appId: "YOUR_APP_ID"
    };
    const ADMIN_SECRET_CODE = "San#2009";
    const ENCRYPTION_KEY_BASE64 = "YOUR_BASE64_KEY";

    firebase.initializeApp(firebaseConfig);
    const auth = firebase.auth();
    const db = firebase.firestore();
    const storage = firebase.storage();

    let currentUser = null;
    let currentUserDoc = null;
    let isAdmin = false;
    let isEditor = false;
    let allArticles = [];
    let siteSettings = {};

    // ---------- Helper functions ----------
    function escapeHtml(str) {
        if (!str) return '';
        return str.replace(/[&<>]/g, function(m) {
            if (m === '&') return '&amp;';
            if (m === '<') return '&lt;';
            if (m === '>') return '&gt;';
            return m;
        });
    }

    // ---------- Theme & Site Settings ----------
    async function applyTheme(theme) {
        if (theme === 'dark') {
            document.body.classList.add('dark');
            document.getElementById('themeToggle').innerHTML = '<i class="fas fa-sun"></i>';
        } else {
            document.body.classList.remove('dark');
            document.getElementById('themeToggle').innerHTML = '<i class="fas fa-moon"></i>';
        }
    }

    async function loadSiteSettings() {
        const doc = await db.collection('siteSettings').doc('config').get();
        if (doc.exists) {
            siteSettings = doc.data();
        } else {
            siteSettings = {
                siteTitle: 'විද්‍යා චින්තන',
                tagline: '∫ සිතුවිල්ලේ අනන්තය දක්වා | විද්‍යාත්මක චින්තනය ළමා සිත් තුළ ∑',
                primaryColor: '#3b82f6',
                secondaryColor: '#10b981',
                bgColor: '#ffffff',
                defaultCover: 'https://images.unsplash.com/photo-1451187580459-43490279c0fa?w=800',
                footerAbout: '"විද්‍යා චින්තන" - ශ්‍රී ලංකාවේ ළමුන් සඳහා නව විද්‍යාත්මක චින්තනයක් ගොඩනැගීමේ අරමුණින් නිර්මාණය කළ සතිපතා විද්‍යා සඟරාව.',
                footerCopyright: '© 2026 විද්‍යා චින්තන - සියලුම හිමිකම් ඇවිරිණි | විද්‍යාවේ අනන්තය සොයා',
                customCss: '',
                customJs: '',
                theme: 'light'
            };
        }
        applyTheme(siteSettings.theme);
        let styleTag = document.getElementById('customSiteStyle');
        if (!styleTag) {
            styleTag = document.createElement('style');
            styleTag.id = 'customSiteStyle';
            document.head.appendChild(styleTag);
        }
        styleTag.innerHTML = siteSettings.customCss || '';
        let scriptTag = document.getElementById('customSiteScript');
        if (scriptTag) scriptTag.remove();
        if (siteSettings.customJs) {
            scriptTag = document.createElement('script');
            scriptTag.id = 'customSiteScript';
            scriptTag.textContent = siteSettings.customJs;
            document.body.appendChild(scriptTag);
        }
        document.getElementById('siteTitle').innerText = siteSettings.siteTitle;
        // Tagline not in a header element, so we can add a simple <p> if needed. We'll skip for brevity.
        document.documentElement.style.setProperty('--primary', siteSettings.primaryColor);
        document.documentElement.style.setProperty('--secondary', siteSettings.secondaryColor);
        document.documentElement.style.setProperty('--bg', siteSettings.bgColor);
        document.body.style.backgroundColor = siteSettings.bgColor;
        document.getElementById('footerAboutText').innerText = siteSettings.footerAbout;
        document.getElementById('footerCopyright').innerText = siteSettings.footerCopyright;
    }

    async function saveSiteSettings() {
        const newSettings = {
            siteTitle: document.getElementById('siteTitleInput').value,
            tagline: document.getElementById('taglineInput').value,
            primaryColor: document.getElementById('primaryColorInput').value,
            secondaryColor: document.getElementById('secondaryColorInput').value,
            bgColor: document.getElementById('bgColorInput').value,
            defaultCover: document.getElementById('defaultCoverInput').value,
            footerAbout: document.getElementById('footerAboutInput').value,
            footerCopyright: document.getElementById('footerCopyrightInput').value,
            customCss: document.getElementById('customCssInput').value,
            customJs: document.getElementById('customJsInput').value,
            theme: siteSettings.theme
        };
        await db.collection('siteSettings').doc('config').set(newSettings, { merge: true });
        await loadSiteSettings();
        document.getElementById('settingsSaveMsg').innerText = 'සුරකින ලදි!';
        setTimeout(() => { document.getElementById('settingsSaveMsg').innerText = ''; }, 3000);
    }

    // ---------- AI Similarity (unchanged) ----------
    function getWordSet(text) {
        const words = text.toLowerCase().split(/\W+/).filter(w => w.length > 3 && !['this','that','have','from','with','what','when','where','which','will','can','the','and','for','are','was','were','but','not','you','your','our','their','there','here'].includes(w));
        return new Set(words);
    }
    function jaccardSimilarity(setA, setB) {
        const intersection = new Set([...setA].filter(x => setB.has(x)));
        const union = new Set([...setA, ...setB]);
        return intersection.size / union.size;
    }
    function getSimilarArticles(currentArticle, allArticles, limit = 3) {
        const currentText = (currentArticle.title + ' ' + currentArticle.content).toLowerCase();
        const currentSet = getWordSet(currentText);
        const scored = allArticles.filter(a => a.id !== currentArticle.id && a.status === 'published').map(art => {
            const artText = (art.title + ' ' + art.content).toLowerCase();
            const artSet = getWordSet(artText);
            const score = jaccardSimilarity(currentSet, artSet);
            return { art, score };
        });
        scored.sort((a,b) => b.score - a.score);
        return scored.slice(0, limit).map(s => s.art);
    }

    // ---------- Load articles & current issue ----------
    async function loadArticles() {
        const snapshot = await db.collection('articles').where('status', '==', 'published').orderBy('publishedAt', 'desc').get();
        allArticles = [];
        let articlesHtml = '';
        snapshot.forEach(doc => {
            const art = doc.data();
            art.id = doc.id;
            allArticles.push(art);
            const tagsHtml = (art.tags || []).map(t => `<span class="card-tag">#${escapeHtml(t)}</span>`).join('');
            articlesHtml += `
                <div class="article-card" data-id="${doc.id}">
                    <img src="${art.imageUrl || siteSettings.defaultCover || 'https://images.unsplash.com/photo-1451187580459-43490279c0fa?w=600'}" class="card-image" loading="lazy">
                    <div class="card-content">
                        <div class="card-title">${escapeHtml(art.title)}</div>
                        <div class="card-meta">📅 ${art.publishedAt ? new Date(art.publishedAt.toDate()).toLocaleDateString('si-LK') : ''} | ✍️ ${escapeHtml(art.authorName)}</div>
                        <div>${tagsHtml}</div>
                    </div>
                </div>
            `;
        });
        document.getElementById('articlesContainer').innerHTML = articlesHtml;
        document.querySelectorAll('.article-card').forEach(card => {
            card.addEventListener('click', () => {
                const id = card.getAttribute('data-id');
                const art = allArticles.find(a => a.id === id);
                if (art) openArticleModal(art);
            });
        });

        const issueGroups = {};
        allArticles.forEach(art => {
            if (art.issueNumber) {
                if (!issueGroups[art.issueNumber]) issueGroups[art.issueNumber] = [];
                issueGroups[art.issueNumber].push(art);
            }
        });
        const sortedIssues = Object.keys(issueGroups).sort().reverse();
        if (sortedIssues.length > 0) {
            const latestIssue = sortedIssues[0];
            const articlesInIssue = issueGroups[latestIssue];
            articlesInIssue.sort((a,b) => (b.publishedAt?.toDate() || 0) - (a.publishedAt?.toDate() || 0));
            let coverImage = siteSettings.defaultCover;
            const issueDoc = await db.collection('issues').doc(latestIssue).get();
            if (issueDoc.exists && issueDoc.data().coverImageUrl) {
                coverImage = issueDoc.data().coverImageUrl;
            } else if (articlesInIssue[0]?.imageUrl) {
                coverImage = articlesInIssue[0].imageUrl;
            }
            let issueHtml = `
                <div class="current-issue">
                    <img src="${coverImage}" class="issue-cover" loading="lazy">
                    <div class="issue-content">
                        <span class="issue-badge">මේ සතියේ කලාපය</span>
                        <div class="issue-title">${escapeHtml(latestIssue)} කලාපය</div>
                        <div class="issue-meta">ලිපි ${articlesInIssue.length}ක්</div>
                        <div class="articles-grid" style="margin-top:1.5rem;">
            `;
            articlesInIssue.forEach(art => {
                issueHtml += `
                    <div class="article-card" data-id="${art.id}">
                        <img src="${art.imageUrl || siteSettings.defaultCover}" class="card-image" style="height:150px;" loading="lazy">
                        <div class="card-content">
                            <div class="card-title">${escapeHtml(art.title)}</div>
                            <div class="card-meta">${escapeHtml(art.authorName)}</div>
                        </div>
                    </div>
                `;
            });
            issueHtml += `</div></div></div>`;
            document.getElementById('currentIssueContainer').innerHTML = issueHtml;
            document.querySelectorAll('#currentIssueContainer .article-card').forEach(card => {
                card.addEventListener('click', () => {
                    const id = card.getAttribute('data-id');
                    const art = allArticles.find(a => a.id === id);
                    if (art) openArticleModal(art);
                });
            });
        } else {
            document.getElementById('currentIssueContainer').innerHTML = '';
        }

        // Trigger fade-up animations
        document.querySelectorAll('.fade-up').forEach(el => {
            const observer = new IntersectionObserver(entries => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('visible');
                        observer.unobserve(entry.target);
                    }
                });
            });
            observer.observe(el);
        });
    }

    async function openArticleModal(article) {
        const modalContent = document.getElementById('modalArticleContent');
        const actionsDiv = document.getElementById('modalActions');
        const markedHtml = marked.parse(article.content || '');
        modalContent.innerHTML = `
            <h2>${escapeHtml(article.title)}</h2>
            <div style="margin-bottom:1rem; color:var(--text-light);">
                ${article.publishedAt ? new Date(article.publishedAt.toDate()).toLocaleDateString('si-LK') : ''} | ${escapeHtml(article.authorName)}
                ${(article.tags || []).map(t => `<span style="background:var(--bg-alt); padding:0.2rem 0.7rem; border-radius:20px; margin-left:0.5rem;">#${escapeHtml(t)}</span>`).join('')}
            </div>
            <div>${markedHtml}</div>
        `;
        actionsDiv.innerHTML = '';
        if (currentUser) {
            const savedRef = db.collection('users').doc(currentUser.uid).collection('saved').doc(article.id);
            const savedDoc = await savedRef.get();
            const isSaved = savedDoc.exists;
            const saveBtn = document.createElement('button');
            saveBtn.textContent = isSaved ? 'සුරකින ලදි' : 'සුරකින්න';
            saveBtn.onclick = async () => {
                if (isSaved) {
                    await savedRef.delete();
                    saveBtn.textContent = 'සුරකින්න';
                } else {
                    await savedRef.set({ articleId: article.id, savedAt: firebase.firestore.FieldValue.serverTimestamp() });
                    saveBtn.textContent = 'සුරකින ලදි';
                }
                await recordHistory(article.id);
                updateRecommendations();
            };
            actionsDiv.appendChild(saveBtn);
        }
        await recordHistory(article.id);
        if (currentUser) updateRecommendations();

        const similar = getSimilarArticles(article, allArticles);
        const similarDiv = document.getElementById('similarList');
        if (similar.length === 0) {
            similarDiv.innerHTML = '<p>සමාන ලිපි හමු නොවුණි.</p>';
        } else {
            let simHtml = '<div class="articles-grid" style="grid-template-columns:repeat(auto-fill, minmax(200px,1fr));">';
            similar.forEach(art => {
                simHtml += `
                    <div class="article-card" data-id="${art.id}">
                        <img src="${art.imageUrl || siteSettings.defaultCover}" class="card-image" style="height:120px;" loading="lazy">
                        <div class="card-content"><div class="card-title">${escapeHtml(art.title)}</div></div>
                    </div>
                `;
            });
            simHtml += '</div>';
            similarDiv.innerHTML = simHtml;
