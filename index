    async function startChat(otherUserId) {
        if (messagesUnsub) messagesUnsub();
        currentChatPartner = otherUserId;
        const otherUserDoc = await db.collection('users').doc(otherUserId).get();
        const otherName = otherUserDoc.data()?.fullName || otherUserDoc.data()?.email || 'Unknown';
        document.getElementById('chatHeader').innerHTML = `<strong>${escapeHtml(otherName)}</strong>`;
        const conversationId = [currentUser.uid, otherUserId].sort().join('_');
        const messagesRef = db.collection('conversations').doc(conversationId).collection('messages').orderBy('timestamp', 'asc');
        messagesUnsub = messagesRef.onSnapshot(async snapshot => {
            let msgsHtml = '';
            for (const doc of snapshot.docs) {
                const msg = doc.data();
                const isSent = msg.senderId === currentUser.uid;
                let text = '🔒 [Encrypted]';
                try {
                    text = await decryptMessage(msg.encrypted);
                } catch (e) { console.error(e); }
                msgsHtml += `<div class="message ${isSent ? 'sent' : 'received'}"><strong>${isSent ? 'මම' : escapeHtml(msg.senderName)}:</strong> ${escapeHtml(text)}<br><small>${msg.timestamp?.toDate().toLocaleTimeString()}</small></div>`;
            }
            document.getElementById('chatMessages').innerHTML = msgsHtml;
            document.getElementById('chatMessages').scrollTop = document.getElementById('chatMessages').scrollHeight;
        });
    }
    async function sendMessage() {
        const text = document.getElementById('chatInput').value.trim();
        if (!text || !currentChatPartner) return;
        const encrypted = await encryptMessage(text);
        const conversationId = [currentUser.uid, currentChatPartner].sort().join('_');
        const senderName = currentUserDoc?.fullName || currentUser.email;
        await db.collection('conversations').doc(conversationId).collection('messages').add({
            senderId: currentUser.uid,
            senderName: senderName,
            encrypted: encrypted,
            timestamp: firebase.firestore.FieldValue.serverTimestamp()
        });
        document.getElementById('chatInput').value = '';
    }

