            gap: 1rem;
            align-items: center;
            padding: 0.8rem 0;
            border-bottom: 1px solid var(--border);
        }
        .schedule-day {
            width: 50px;
            height: 50px;
            background: var(--primary);
            color: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
        }

        .creators-section {
            background: var(--bg-alt);
            padding: 4rem 0;
            margin: 4rem 0;
        }
        .creators-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 2rem;
            margin-top: 2rem;
