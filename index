    <style>
        /* ========== CSS Variables (light mode default) ========== */
        :root {
            --bg: #ffffff;
            --bg-alt: #f8fafc;
            --text: #0f172a;
            --text-light: #475569;
            --primary: #3b82f6;
            --secondary: #10b981;
            --accent: #f59e0b;
            --border: #e2e8f0;
            --card-bg: #ffffff;
            --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
            --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
            --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
        }
        body.dark {
            --bg: #0f172a;
            --bg-alt: #1e293b;
            --text: #f1f5f9;
            --text-light: #94a3b8;
            --primary: #60a5fa;
            --secondary: #34d399;
            --border: #334155;
            --card-bg: #1e293b;
            --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.3);
