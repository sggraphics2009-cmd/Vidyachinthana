            font-size: 2rem;
            font-weight: 800;
            line-height: 1.2;
            margin: 0.5rem 0;
        }
        .issue-meta { color: var(--text-light); margin-bottom: 1rem; }

        .main-container {
            display: grid;
            grid-template-columns: 1fr;
            gap: 2rem;
            margin: 2rem 0;
        }
        @media (min-width: 992px) { .main-container { grid-template-columns: 2fr 1fr; } }

        .articles-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 1.5rem;
        }
        .article-card {
            background: var(--card-bg);
            border-radius: 1rem;
            overflow: hidden;
            box-shadow: var(--shadow-sm);
            transition: all 0.3s cubic-bezier(0.2, 0, 0, 1);
            cursor: pointer;
            border: 1px solid var(--border);
        }
        .article-card:hover {
            transform: translateY(-6px);
            box-shadow: var(--shadow-lg);
            border-color: var(--primary);
        }
        .card-image { width: 100%; height: 200px; object-fit: cover; transition: transform 0.5s; }
        .article-card:hover .card-image { transform: scale(1.03); }
        .card-content { padding: 1.2rem; }
        .card-title { font-size: 1.2rem; font-weight: 700; margin-bottom: 0.5rem; }
        .card-meta { font-size: 0.75rem; color: var(--text-light); margin-bottom: 0.5rem; display: flex; gap: 0.5rem; flex-wrap: wrap; }
